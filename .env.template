## Copy this file to ".env" and fill in values as needed.

# URL for the OAuth proxy server used by the Flask backend
# Example when using docker-compose: http://oauth-proxy-server:4000/
PROXY_SERVER_URL=

# Secret key for Flask sessions (keep this secret in production!)
# You can use `python -c "import secrets; print(secrets.token_hex(32))"` to generate one.
SECRET_KEY=

# GitHub OAuth App credentials
# Create a GitHub OAuth App and set these values.
# Used by:
# - Frontend build arg `REACT_APP_GITHUB_CLIENT_ID` (via docker-compose)
# - oauth-proxy-server container env vars `CLIENT_ID` and `CLIENT_SECRET`
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
